---
interface Props {
  // Base path anchors resolve against — "" on the homepage, "/" (with trailing slash before the #) elsewhere.
  base?: string;
}

const { base = '/' } = Astro.props;
---

<header
  style="position:sticky;top:0;z-index:10;display:flex;justify-content:space-between;align-items:center;padding:22px 0;background:rgba(250,248,244,.85);backdrop-filter:blur(8px);border-bottom:1px solid #ece6da"
>
  <a href={`${base}#top`} class="sans" style="font-size:13px;font-weight:600;letter-spacing:.01em">Chris Matthews</a>
  <nav
    class="sans"
    style="display:flex;gap:24px;font-size:11px;font-weight:500;letter-spacing:.1em;text-transform:uppercase;color:#6f6a60"
  >
    <a href={`${base}#about`}>About</a>
    <a href={`${base}#now`}>Now</a>
    <a href={`${base}#work`}>Projects</a>
    <a href={`${base}#writing`}>Writing</a>
    <a href={`${base}#contact`}>Contact</a>
  </nav>
</header>
